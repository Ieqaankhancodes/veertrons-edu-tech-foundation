# Base URL for the backend API (no trailing slash).
# Optional browser-direct API URL (no trailing slash).
# Example:
# VITE_API_URL=https://your-backend.example.com
#
# For local dev you can leave this blank and use the Vite proxy in `vite.config.js`.
VITE_API_URL=

# Used by Vercel's `/api/*` proxy in `api/[...path].js`.
# Example:
# RENDER_API_URL=https://your-render-service.onrender.com
RENDER_API_URL=
